<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="010-create-mileage" author="finance-app">
        <createTable tableName="vehicle_mileage">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_mileage_user"
                             references="users(id)"/>
            </column>
            <column name="fill_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="litres" type="NUMERIC(6,3)"/>
            <column name="odometer_reading" type="NUMERIC(8,1)"/>
            <column name="distance_km" type="NUMERIC(8,1)"/>
            <column name="mileage_kmpl" type="NUMERIC(6,3)"/>
            <column name="fuel_price" type="NUMERIC(7,2)"/>
            <column name="total_cost" type="NUMERIC(9,2)"/>
            <column name="cc_charges" type="NUMERIC(7,2)" defaultValueNumeric="0"/>
            <column name="service_charges" type="NUMERIC(8,2)" defaultValueNumeric="0"/>
            <column name="service_date" type="DATE"/>
            <column name="service_cost" type="NUMERIC(9,2)" defaultValueNumeric="0"/>
        </createTable>
        <createIndex tableName="vehicle_mileage" indexName="idx_mileage_date">
            <column name="user_id"/>
            <column name="fill_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
