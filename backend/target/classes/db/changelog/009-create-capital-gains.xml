<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="009-create-capital-gains" author="finance-app">
        <createTable tableName="capital_gains_equity">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_cge_user"
                             references="users(id)"/>
            </column>
            <column name="financial_year" type="VARCHAR(9)"/>
            <column name="scrip_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="NUMERIC(12,4)"/>
            <column name="purchase_price" type="NUMERIC(12,4)"/>
            <column name="purchase_brokerage" type="NUMERIC(10,2)" defaultValueNumeric="0"/>
            <column name="purchase_date" type="DATE"/>
            <column name="sell_price" type="NUMERIC(12,4)"/>
            <column name="sell_brokerage" type="NUMERIC(10,2)" defaultValueNumeric="0"/>
            <column name="sell_date" type="DATE"/>
            <column name="gain_loss" type="NUMERIC(14,2)"/>
            <column name="gain_type" type="VARCHAR(2)"/>
            <!-- LT or ST -->
            <column name="lt_gain" type="NUMERIC(14,2)" defaultValueNumeric="0"/>
            <column name="st_gain" type="NUMERIC(14,2)" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createTable tableName="capital_gains_property">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_cgp_user"
                             references="users(id)"/>
            </column>
            <column name="financial_year" type="VARCHAR(9)"/>
            <column name="property_description" type="VARCHAR(200)"/>
            <column name="purchase_price" type="NUMERIC(14,2)"/>
            <column name="purchase_date" type="DATE"/>
            <column name="sell_price" type="NUMERIC(14,2)"/>
            <column name="sell_date" type="DATE"/>
            <column name="cii_purchase_year" type="INT"/>
            <column name="cii_sell_year" type="INT"/>
            <column name="lt_gain_with_index" type="NUMERIC(14,2)" defaultValueNumeric="0"/>
            <column name="lt_gain_without_index" type="NUMERIC(14,2)" defaultValueNumeric="0"/>
            <column name="st_gain" type="NUMERIC(14,2)" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
